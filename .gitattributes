# 強制所有文字檔案使用 LF 換行符,避免跨電腦、跨工具的換行符衝突
# 設定後請執行一次:git add --renormalize .

* text=auto eol=lf

*.md       text eol=lf
*.txt      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# 二進位檔案,不做換行符轉換
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.pdf      binary
*.docx     binary
*.pptx     binary
*.xlsx     binary
*.zip      binary
*.mp3      binary
*.mp4      binary
